generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id
  email             String             @unique
  fullName          String?            @map("full_name")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  aiSettings        AiSettings?
  analyticsNotes    AnalyticsNote[]
  chatbotSessions   ChatbotSession[]
  instagramAccounts InstagramAccount[]
  mediaAssets       MediaAsset[]
  googleIntegration GoogleIntegration?

  @@map("users")
}

model GoogleIntegration {
  id                    String   @id @default(uuid())
  userId                String   @unique @map("user_id")
  refreshTokenEncrypted String   @map("refresh_token_encrypted")
  scope                 String
  connectedAt           DateTime @default(now()) @map("connected_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("google_integrations")
}

model InstagramAccount {
  id                   String               @id @default(uuid())
  userId               String               @map("user_id")
  igUserId             String               @map("ig_user_id")
  username             String
  accountType          InstagramAccountType @map("account_type")
  avatarUrl            String?              @map("avatar_url")
  accessTokenEncrypted String               @map("access_token_encrypted")
  pageId               String?              @map("page_id")
  isActive             Boolean              @default(true) @map("is_active")
  tokenExpiresAt       DateTime?            @map("token_expires_at")
  connectedAt          DateTime             @default(now()) @map("connected_at")
  disconnectedAt       DateTime?            @map("disconnected_at")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  analyticsSnapshots   AnalyticsSnapshot[]
  analyticsNotes       AnalyticsNote[]
  chatbotSessions      ChatbotSession[]
  contentPosts         ContentPost[]
  dmConversations      DmConversation[]
  instagramStories     InstagramStory[]
  aiKnowledge          AiKnowledge[]
  aiProcedures         AiProcedure[]
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  webhookEvents        WebhookEvent[]

  @@index([userId])
  @@index([isActive])
  @@index([disconnectedAt])
  @@map("instagram_accounts")
}

model InstagramStory {
  id                 String           @id @default(uuid())
  instagramAccountId String           @map("instagram_account_id")
  igStoryId          String           @unique @map("ig_story_id")
  mediaType          String?          @map("media_type")
  mediaProductType   String?          @map("media_product_type")
  permalink          String?
  timestamp          DateTime?
  firstSeenAt        DateTime         @default(now()) @map("first_seen_at")
  lastSeenAt         DateTime         @default(now()) @map("last_seen_at")
  expiresAt          DateTime?        @map("expires_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  instagramAccount   InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  @@index([instagramAccountId])
  @@index([timestamp])
  @@index([expiresAt])
  @@map("instagram_stories")
}

model MediaAsset {
  id              String      @id @default(uuid())
  userId          String      @map("user_id")
  storagePath     String      @map("storage_path")
  fileType        MediaType   @map("file_type")
  mimeType        String      @map("mime_type")
  fileSize        Int         @map("file_size")
  width           Int?
  height          Int?
  durationSeconds Int?        @map("duration_seconds")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  postMedia       PostMedia[]

  @@index([userId])
  @@map("media_assets")
}

model ContentPost {
  id                 String           @id @default(uuid())
  instagramAccountId String           @map("instagram_account_id")
  title              String?
  caption            String?
  postType           PostType         @map("post_type")
  status             PostStatus       @default(DRAFT)
  scheduledFor       DateTime?        @map("scheduled_for")
  publishedAt        DateTime?        @map("published_at")
  igMediaId          String?          @map("ig_media_id")
  igMediaContainerId String?          @map("ig_media_container_id")
  igPermalink        String?          @map("ig_permalink")
  isAiGenerated      Boolean          @default(false) @map("is_ai_generated")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  instagramAccount   InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  postAnalytics      PostAnalytics[]
  postMedia          PostMedia[]
  publishAttempts    PublishAttempt[]

  @@index([instagramAccountId])
  @@index([status])
  @@index([scheduledFor])
  @@index([instagramAccountId, status, scheduledFor])
  @@map("content_posts")
}

model PostMedia {
  id            String      @id @default(uuid())
  contentPostId String      @map("content_post_id")
  mediaAssetId  String      @map("media_asset_id")
  sortOrder     Int         @default(0) @map("sort_order")
  contentPost   ContentPost @relation(fields: [contentPostId], references: [id], onDelete: Cascade)
  mediaAsset    MediaAsset  @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  @@unique([contentPostId, sortOrder])
  @@unique([contentPostId, mediaAssetId])
  @@index([mediaAssetId])
  @@map("post_media")
}

model PublishAttempt {
  id            String               @id @default(uuid())
  contentPostId String               @map("content_post_id")
  trigger       PublishTrigger
  status        PublishAttemptStatus @default(STARTED)
  attemptNumber Int                  @map("attempt_number")
  startedAt     DateTime             @default(now()) @map("started_at")
  finishedAt    DateTime?            @map("finished_at")
  errorCode     String?              @map("error_code")
  errorMessage  String?              @map("error_message")
  responseJson  Json?                @map("response_json")
  jobReference  String?              @map("job_reference")
  createdAt     DateTime             @default(now()) @map("created_at")
  contentPost   ContentPost          @relation(fields: [contentPostId], references: [id], onDelete: Cascade)

  @@unique([contentPostId, attemptNumber])
  @@index([contentPostId])
  @@index([status])
  @@index([startedAt])
  @@map("publish_attempts")
}

model WebhookEvent {
  id                 String                  @id @default(uuid())
  instagramAccountId String?                 @map("instagram_account_id")
  source             WebhookSource
  eventType          String                  @map("event_type")
  externalEventId    String?                 @map("external_event_id")
  payload            Json
  processingStatus   WebhookProcessingStatus @default(RECEIVED) @map("processing_status")
  receivedAt         DateTime                @default(now()) @map("received_at")
  processedAt        DateTime?               @map("processed_at")
  errorMessage       String?                 @map("error_message")
  instagramAccount   InstagramAccount?       @relation(fields: [instagramAccountId], references: [id], onDelete: SetNull)

  @@index([instagramAccountId])
  @@index([source, eventType])
  @@index([processingStatus])
  @@index([receivedAt])
  @@map("webhook_events")
}

model DmConversation {
  id                  String           @id @default(uuid())
  instagramAccountId  String           @map("instagram_account_id")
  igConversationId    String           @unique @map("ig_conversation_id")
  participantIgId     String           @map("participant_ig_id")
  participantUsername String?          @map("participant_username")
  lastMessageAt       DateTime?        @map("last_message_at")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")
  instagramAccount    InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)
  dmMessages          DmMessage[]

  @@index([instagramAccountId])
  @@index([lastMessageAt])
  @@map("dm_conversations")
}

model DmMessage {
  id             String         @id @default(uuid())
  conversationId String         @map("conversation_id")
  igMessageId    String         @unique @map("ig_message_id")
  senderType     DmSenderType   @map("sender_type")
  messageText    String?        @map("message_text")
  sentAt         DateTime       @map("sent_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  conversation   DmConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([sentAt])
  @@map("dm_messages")
}

model AnalyticsSnapshot {
  id                 String           @id @default(uuid())
  instagramAccountId String           @map("instagram_account_id")
  snapshotDate       DateTime         @map("snapshot_date") @db.Date
  followersCount     Int              @map("followers_count")
  followingCount     Int              @map("following_count")
  mediaCount         Int              @map("media_count")
  reach              Int?
  impressions        Int?
  profileViews       Int?             @map("profile_views")
  createdAt          DateTime         @default(now()) @map("created_at")
  instagramAccount   InstagramAccount @relation(fields: [instagramAccountId], references: [id], onDelete: Cascade)

  @@unique([instagramAccountId, snapshotDate])
  @@index([snapshotDate])
  @@map("analytics_snapshots")
}

model PostAnalytics {
  id            String      @id @default(uuid())
  contentPostId String      @map("content_post_id")
  fetchedAt     DateTime    @default(now()) @map("fetched_at")
  likeCount     Int?        @map("like_count")
  commentsCount Int?        @map("comments_count")
  sharesCount   Int?        @map("shares_count")
  savesCount    Int?        @map("saves_count")
  reach         Int?
  impressions   Int?
  engagement    Int?
  contentPost   ContentPost @relation(fields: [contentPostId], references: [id], onDelete: Cascade)

  @@unique([contentPostId, fetchedAt])
  @@index([contentPostId])
  @@index([fetchedAt])
  @@map("post_analytics")
}

model AnalyticsNote {
  id                 String            @id @default(uuid())
  userId             String            @map("user_id")
  instagramAccountId String?           @map("instagram_account_id")
  body               String
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  instagramAccount   InstagramAccount? @relation(fields: [instagramAccountId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
  @@index([instagramAccountId])
  @@map("analytics_notes")
}

model AiSettings {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  preferredTone      String?  @map("preferred_tone")
  preferredLanguage  String   @default("en") @map("preferred_language")
  customInstructions String?  @map("custom_instructions")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_settings")
}

model ChatbotSession {
  id                 String            @id @default(uuid())
  userId             String            @map("user_id")
  instagramAccountId String?           @map("instagram_account_id")
  title              String?
  startedAt          DateTime          @default(now()) @map("started_at")
  lastActiveAt       DateTime          @default(now()) @map("last_active_at")
  messages           ChatbotMessage[]
  instagramAccount   InstagramAccount? @relation(fields: [instagramAccountId], references: [id], onDelete: SetNull)
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([instagramAccountId])
  @@index([lastActiveAt])
  @@map("chatbot_sessions")
}

model ChatbotMessage {
  id         String             @id @default(uuid())
  sessionId  String             @map("session_id")
  role       ChatbotMessageRole
  content    String
  tokensUsed Int?               @map("tokens_used")
  createdAt  DateTime           @default(now()) @map("created_at")
  session    ChatbotSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
  @@map("chatbot_messages")
}

enum InstagramAccountType {
  PERSONAL
  BUSINESS
  CREATOR
}

enum MediaType {
  IMAGE
  VIDEO
}

enum PostType {
  FEED
  REEL
  STORY
  CAROUSEL
}

enum PostStatus {
  DRAFT
  PENDING
  READY
  PUBLISHED
}

enum PublishTrigger {
  MANUAL
  SCHEDULED
  RETRY
}

enum PublishAttemptStatus {
  STARTED
  SUCCESS
  FAILED
}

enum WebhookSource {
  INSTAGRAM
  FACEBOOK
}

enum WebhookProcessingStatus {
  RECEIVED
  PROCESSED
  FAILED
}

enum DmSenderType {
  USER
  PARTICIPANT
}

enum ChatbotMessageRole {
  USER
  ASSISTANT
}

model AiKnowledge {
  id         String           @id @default(cuid())
  accountId  String           @map("account_id")
  category   String
  fact       String
  confidence Float            @default(0.8)
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")
  account    InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("ai_knowledge")
}

model AiProcedure {
  id              String           @id @default(cuid())
  accountId       String           @map("account_id")
  strategy        String
  outcome         String?
  engagementDelta Float?           @map("engagement_delta")
  savesDelta      Float?           @map("saves_delta")
  appliedAt       DateTime         @default(now()) @map("applied_at")
  resolvedAt      DateTime?        @map("resolved_at")
  account         InstagramAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("ai_procedures")
}
