{
  "name": "@social-manager/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",

  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },

  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prebuild": "prisma generate",
    "build": "tsc -p tsconfig.json",
    "pretypecheck": "prisma generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prisma": "^6.6.0",
    "typescript": "^5.7.3"
  }
}
